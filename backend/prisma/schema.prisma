generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String?
  avatar         String?
  provider       String          @default("local")
  googleId       String?
  linkedinId     String?
  settings       Json?           @default("{}")
  role           UserRole        @default(USER)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  metrics        Metric[]
  posts          Post[]
  carousels      Carousel[]
  products       Product[]
  calendar       ContentCalendar[]
  knowledgeBase  KnowledgeBase[]
  contentSuggestions ContentSuggestion[]
  generatedContents  GeneratedContent[]
  scheduledPosts     ScheduledPost[]
}

model AdminSession {
  id           String    @id @default(cuid())
  adminId      String
  targetUserId String
  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  @@index([adminId])
  @@index([targetUserId])
}

model Carousel {
  id          String          @id @default(cuid())
  userId      String
  title       String
  platform    String          @default("linkedin")
  slides      Json            // array de slides
  status      String          @default("draft") // draft | scheduled | published
  scheduledAt DateTime?
  publishedAt DateTime?
  linkedinUrn String?         // URN retornado após publicar
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  accessToken String
  pageId      String?
  pageName    String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, platform])
}

model Metric {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  date        DateTime
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  views       Int      @default(0)
  followers   Int      @default(0)
  reach       Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String          @id @default(cuid())
  userId      String
  platform    String
  content     String
  cta         String?
  hashtags    String?
  status      String          @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendar    ContentCalendar[]
}

model Product {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  url       String
  price     Float?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentCalendar {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  platform  String
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  content   String   @db.Text
  url       String?
  filename  String?
  fileSize  Int?
  tags      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentSuggestion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      String   // 'google' | 'linkedin'
  headline    String
  url         String
  snippet     String?
  fetchedAt   DateTime @default(now())
  usedAt      DateTime?
  generated   GeneratedContent[]
  @@index([userId, source, fetchedAt])
}

model GeneratedContent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestionId String
  suggestion  ContentSuggestion @relation(fields: [suggestionId], references: [id])
  text        String   @db.Text
  hashtags    String[]
  template    String   // 'post' | 'carousel' | 'article'
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  scheduled   ScheduledPost[]
  @@index([userId, status])
}

model ScheduledPost {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentId   String
  content     GeneratedContent @relation(fields: [contentId], references: [id])
  publishAt   DateTime
  recurrence  String   @default("none") // none | daily
  platform    String   @default("linkedin")
  status      String   @default("scheduled")
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  @@index([userId, status, publishAt])
}
