generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String?
  avatar         String?
  provider       String          @default("local")
  googleId       String?
  linkedinId     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  metrics        Metric[]
  posts          Post[]
  products       Product[]
  calendar       ContentCalendar[]
  knowledgeBase  KnowledgeBase[]
  weeklyContents WeeklyContent[]
  ideas          Idea[]
  generatorSettings GeneratorSettings?
  analyticsSnapshots AnalyticsSnapshot[]
}

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  accessToken String
  pageId      String?
  pageName    String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, platform])
}

model Metric {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  date        DateTime
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  views       Int      @default(0)
  followers   Int      @default(0)
  reach       Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String          @id @default(cuid())
  userId      String
  platform    String
  content     String
  cta         String?
  hashtags    String?
  category    String?
  status      String          @default("draft")
  scheduledAt DateTime?
  publishedAt DateTime?
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendar    ContentCalendar[]
}

model Product {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  url       String
  price     Float?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContentCalendar {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  platform  String
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  content   String   @db.Text
  url       String?
  filename  String?
  fileSize  Int?
  tags      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyContent {
  id        String   @id @default(cuid())
  theme     String
  tone      String
  platform  String
  posts     Json
  userId    String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id          String   @id @default(cuid())
  userId      String
  hook        String
  breakText   String
  pain        String
  agitate     String
  solution    String
  proof       String
  cta         String
  category    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GeneratorSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  instructions  String  @default("Gere conteúdo profissional para eletricistas. Use tom técnico mas acessível. Máximo 1300 caracteres para LinkedIn.")
  tone          String  @default("mix")
  linkedinUrl   String?
  facebookUrl   String?
  siteUrl       String?
  otherUrl      String?
  linkedinToken String?
  facebookToken String?
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsSnapshot {
  id            String   @id @default(cuid())
  userId        String
  platform      String
  followers     Int      @default(0)
  views         Int      @default(0)
  shares        Int      @default(0)
  likes         Int      @default(0)
  comments      Int      @default(0)
  sales         Int      @default(0)
  snapshotDate  DateTime @default(now())
  analysisText  String?  @db.Text
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
